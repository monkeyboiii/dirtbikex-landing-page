---
import '../styles/global.css';
import '../styles/landing.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations, switchLangPath } from '../i18n/utils';
import { defaultLang, languages, rtlLocales, type Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title = t('meta.title'), description = t('meta.description') } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const dir = rtlLocales.includes(lang) ? 'rtl' : 'ltr';
const localeCodes = Object.keys(languages) as Lang[];

const hreflangs = localeCodes.map((code) => ({
  code,
  href: new URL(switchLangPath(Astro.url, code), Astro.site).toString(),
}));
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ed6b00" />
    <link rel="canonical" href={canonical.toString()} />
    {hreflangs.map((h) => (
      <link rel="alternate" hreflang={h.code} href={h.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={hreflangs.find((h) => h.code === 'en')?.href ?? canonical.toString()} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site).toString()} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline define:vars={{ localeCodes, defaultLang }}>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
      // Browser-locale auto-redirect.
      // Runs on EN root paths only (paths under any non-EN locale prefix are skipped).
      // Respects explicit user choice from the LangSwitcher dropdown
      // (localStorage 'dbx-locale-pref'). Silent — no banner.
      (function () {
        try {
          const path = window.location.pathname;
          const locales = Array.isArray(localeCodes) ? localeCodes : [defaultLang];
          const localeSet = new Set(locales);
          const segments = path.split('/').filter(Boolean);

          if (segments.length > 1 && localeSet.has(segments[0]) && segments[1] === segments[0]) {
            let restStart = 1;
            while (restStart < segments.length && segments[restStart] === segments[0]) restStart++;
            const rest = segments.slice(restStart).join('/');
            const targetPath = '/' + segments[0] + (rest ? '/' + rest + (path.endsWith('/') ? '/' : '') : '/');
            window.location.replace(targetPath + window.location.search + window.location.hash);
            return;
          }

          // Worker-handled share routes use ?lang= (URL-prefix would break the
          // AASA `/s/*` deep-link contract and 404 on the asset layer).
          if (path.indexOf('/s/') === 0) return;

          for (let i = 0; i < locales.length; i++) {
            const code = locales[i];
            if (code === defaultLang) continue;
            const prefix = '/' + code;
            if (path === prefix || path.indexOf(prefix + '/') === 0) return;
          }

          function matchLocale(tag) {
            const lower = String(tag || '').trim().replace(/_/g, '-').toLowerCase();
            if (!lower) return null;
            for (let i = 0; i < locales.length; i++) {
              if (locales[i].toLowerCase() === lower) return locales[i];
            }
            const base = lower.split('-')[0];
            if (base === 'zh') {
              const want = /hant|tw|hk|mo/.test(lower) ? 'zh-TW' : 'zh-CN';
              return localeSet.has(want) ? want : null;
            }
            for (let i = 0; i < locales.length; i++) {
              if (locales[i].toLowerCase().split('-')[0] === base) return locales[i];
            }
            return null;
          }

          const pref = matchLocale(localStorage.getItem('dbx-locale-pref'));
          if (pref === defaultLang) return;
          if (pref) {
            const target = '/' + pref + (path === '/' ? '/' : path);
            window.location.replace(target + window.location.search + window.location.hash);
            return;
          }

          const browserLangs = navigator.languages && navigator.languages.length
            ? navigator.languages
            : [navigator.language || defaultLang];
          for (let i = 0; i < browserLangs.length; i++) {
            const match = matchLocale(browserLangs[i]);
            if (match === defaultLang) return;
            if (match) {
              const target = '/' + match + (path === '/' ? '/' : path);
              window.location.replace(target + window.location.search + window.location.hash);
              return;
            }
          }
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      // Preserve scroll position across a language switch (header picker or
      // footer locale row). A switch is a full navigation to a different-
      // locale URL, which would otherwise reset scroll to the top.
      //
      // Absolute scrollY doesn't transfer well (translated text changes
      // section heights), so on click we record the on-screen section nearest
      // the top of the viewport plus its offset, and on the next page re-pin
      // that same element to the same offset — re-applying through a short
      // settling window so async featured-thread images don't drift it. Falls
      // back to absolute scrollY when no anchor element is available. Read
      // only on DOMContentLoaded/load so it survives the auto-redirect above.
      (function () {
        var KEY = 'dbx-lang-scroll';
        var REF = 96; // reference line just below the sticky header
        function setY(y) {
          var el = document.documentElement;
          var prev = el.style.scrollBehavior;
          el.style.scrollBehavior = 'auto'; // bypass CSS smooth-scroll
          window.scrollTo(0, Math.max(0, y));
          el.style.scrollBehavior = prev;
        }
        function read() {
          try {
            var d = JSON.parse(sessionStorage.getItem(KEY));
            if (!d || (Date.now() - d.t) > 10000) return null;
            return d;
          } catch (e) { return null; }
        }
        function clear() { try { sessionStorage.removeItem(KEY); } catch (e) {} }
        function apply(d) {
          if (d.sel) {
            var el = document.querySelector(d.sel);
            if (el) { setY(window.scrollY + (el.getBoundingClientRect().top - d.off)); return; }
          }
          if (typeof d.y === 'number') setY(d.y);
        }

        var data = null;
        document.addEventListener('DOMContentLoaded', function () {
          data = read();
          if (data) apply(data);
        });
        window.addEventListener('load', function () {
          if (!data) data = read();
          if (!data) return;
          var stop = false;
          ['wheel', 'touchstart', 'keydown', 'pointerdown'].forEach(function (ev) {
            window.addEventListener(ev, function () { stop = true; }, { once: true, passive: true });
          });
          // Re-pin every frame until the document height stays stable for a
          // beat (async featured-thread images load well after `load` and grow
          // the page above the anchor). Cap the window; bail on user input.
          var cap = Date.now() + 6000, lastH = -1, lastChange = Date.now();
          (function loop() {
            var h = document.documentElement.scrollHeight;
            if (h !== lastH) { lastH = h; lastChange = Date.now(); }
            apply(data);
            var settled = (Date.now() - lastChange) > 500;
            if (!stop && !settled && Date.now() < cap) requestAnimationFrame(loop);
            else clear();
          })();
        });
        document.addEventListener('click', function (e) {
          var a = e.target && e.target.closest ? e.target.closest('[data-lang-link]') : null;
          if (!a) return;
          var payload = { y: window.scrollY, t: Date.now() };
          // anchor to the visible in-flow [id] element nearest the reference
          // line. Scope to <main> so sticky header/footer ids (which never
          // move with scroll) can't win and make the restore a no-op.
          var els = document.querySelectorAll('main [id]'), best = null, bestDist = Infinity;
          for (var i = 0; i < els.length; i++) {
            var el = els[i];
            if (!el.id || el.offsetParent === null) continue;
            var r = el.getBoundingClientRect();
            if (r.height <= 0) continue;
            var dist = Math.abs(r.top - REF);
            if (dist < bestDist) { bestDist = dist; best = el; }
          }
          if (best) {
            try { payload.sel = '#' + (window.CSS && CSS.escape ? CSS.escape(best.id) : best.id); } catch (e3) {}
            payload.off = best.getBoundingClientRect().top;
          }
          try { sessionStorage.setItem(KEY, JSON.stringify(payload)); } catch (e2) {}
        }, true);
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
