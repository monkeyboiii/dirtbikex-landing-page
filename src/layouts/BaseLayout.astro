---
import '../styles/global.css';
import '../styles/landing.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations, switchLangPath } from '../i18n/utils';
import { languages, rtlLocales, type Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title = t('meta.title'), description = t('meta.description') } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const dir = rtlLocales.includes(lang) ? 'rtl' : 'ltr';

const hreflangs = (Object.keys(languages) as Lang[]).map((code) => ({
  code,
  href: new URL(switchLangPath(Astro.url, code), Astro.site).toString(),
}));
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ed6b00" />
    <link rel="canonical" href={canonical.toString()} />
    {hreflangs.map((h) => (
      <link rel="alternate" hreflang={h.code} href={h.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={hreflangs.find((h) => h.code === 'en')?.href ?? canonical.toString()} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site).toString()} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
      // Browser-locale auto-redirect.
      // Runs on EN root paths only (paths under any non-EN locale prefix are skipped).
      // Respects explicit user choice from the LangSwitcher dropdown
      // (localStorage 'dbx-locale-pref'). Silent — no banner.
      (function () {
        try {
          const path = window.location.pathname;
          const prefixes = ['/zh-CN', '/zh-TW', '/ja', '/ko', '/de', '/it', '/fr', '/es', '/ar', '/da', '/el', '/fa-IR', '/fi', '/id', '/nl', '/pt', '/tr-TR', '/th', '/vi'];
          for (let i = 0; i < prefixes.length; i++) {
            if (path === prefixes[i] || path.indexOf(prefixes[i] + '/') === 0) return;
          }
          const pref = localStorage.getItem('dbx-locale-pref');
          if (pref === 'en') return;
          if (pref && pref !== 'en') {
            const target = '/' + pref + (path === '/' ? '/' : path);
            window.location.replace(target + window.location.search + window.location.hash);
            return;
          }
          // BCP-47 → shipped-locale matcher. Order matters: more-specific
          // matches first (zh-Hant before zh, etc.).
          function matchLocale(lower) {
            if (lower === 'en' || lower.indexOf('en-') === 0) return 'en';
            if (lower === 'zh-tw' || lower === 'zh-hk' || lower === 'zh-hant' || lower.indexOf('zh-hant') === 0 || lower.indexOf('zh-mo') === 0) return 'zh-TW';
            if (lower === 'zh' || lower === 'zh-cn' || lower === 'zh-hans' || lower.indexOf('zh-hans') === 0 || lower.indexOf('zh-sg') === 0) return 'zh-CN';
            if (lower === 'ja' || lower.indexOf('ja-') === 0) return 'ja';
            if (lower === 'ko' || lower.indexOf('ko-') === 0) return 'ko';
            if (lower === 'de' || lower.indexOf('de-') === 0) return 'de';
            if (lower === 'it' || lower.indexOf('it-') === 0) return 'it';
            if (lower === 'fr' || lower.indexOf('fr-') === 0) return 'fr';
            if (lower === 'es' || lower.indexOf('es-') === 0) return 'es';
            if (lower === 'ar' || lower.indexOf('ar-') === 0) return 'ar';
            if (lower === 'da' || lower.indexOf('da-') === 0) return 'da';
            if (lower === 'el' || lower.indexOf('el-') === 0) return 'el';
            if (lower === 'fa' || lower.indexOf('fa-') === 0) return 'fa-IR';
            if (lower === 'fi' || lower.indexOf('fi-') === 0) return 'fi';
            if (lower === 'id' || lower.indexOf('id-') === 0) return 'id';
            if (lower === 'nl' || lower.indexOf('nl-') === 0) return 'nl';
            if (lower === 'pt' || lower.indexOf('pt-') === 0) return 'pt';
            if (lower === 'tr' || lower.indexOf('tr-') === 0) return 'tr-TR';
            if (lower === 'th' || lower.indexOf('th-') === 0) return 'th';
            if (lower === 'vi' || lower.indexOf('vi-') === 0) return 'vi';
            return null;
          }
          const browserLangs = navigator.languages && navigator.languages.length
            ? navigator.languages
            : [navigator.language || 'en'];
          for (let i = 0; i < browserLangs.length; i++) {
            const match = matchLocale(String(browserLangs[i] || '').toLowerCase());
            if (match === 'en') return;
            if (match) {
              const target = '/' + match + (path === '/' ? '/' : path);
              window.location.replace(target + window.location.search + window.location.hash);
              return;
            }
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
