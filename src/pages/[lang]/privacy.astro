---
import LegalLayout from '../../layouts/LegalLayout.astro';
import { Content as EnContent, frontmatter as enFm } from '../../content/legal/privacy.en.mdx';
import { Content as ZhCNContent, frontmatter as zhCNFm } from '../../content/legal/privacy.zh-CN.mdx';
import { getLangFromUrl } from '../../i18n/utils';
import { nonEnLocales } from '../../i18n/ui';

export function getStaticPaths() {
  return nonEnLocales.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const useZhCN = lang === 'zh-CN';
const Content = useZhCN ? ZhCNContent : EnContent;
const frontmatter = useZhCN ? zhCNFm : enFm;
const fallbackScope = useZhCN ? null : 'fallback';
---

<LegalLayout
  title={frontmatter.title}
  lastUpdated={frontmatter.lastUpdated}
  fallbackScope={fallbackScope}
>
  <Content />
</LegalLayout>
