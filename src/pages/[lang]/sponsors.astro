---
// Locale mirror of /sponsors. Pre-renders for every non-en locale; the sponsor
// data (faces + counts) is language-agnostic, so only the chrome copy differs.
// Worker proxy /api/proxy/sponsors is locale-independent.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { APP_STORE_URL, FORUM_BASE } from '../../config';
import { nonEnLocales } from '../../i18n/ui';

export function getStaticPaths() {
  return nonEnLocales.map((lang) => ({ params: { lang } }));
}
---

<BaseLayout title="Sponsors — DirtBikeX">
  <section class="mx-auto max-w-4xl px-4 py-16">
    <h1 class="text-4xl font-bold mb-4">Sponsors</h1>
    <p class="text-gray-600 dark:text-gray-300 mb-12">
      The brands and individuals supporting the DirtBikeX community.
    </p>

    <div id="sponsors-app" data-forum-base={FORUM_BASE}>
      <p id="sponsors-loading" class="text-gray-500 italic">Loading sponsors…</p>
      <div id="sponsors-error" class="hidden text-amber-600 dark:text-amber-300">
        Couldn't load sponsors right now. Try again later.
      </div>
      <div id="sponsors-content" class="hidden"></div>
      <div id="sponsors-empty" class="hidden text-gray-500 italic">
        No active sponsors yet.
        <a href={APP_STORE_URL} class="text-blue-600 underline">Get DirtBikeX</a> and grab a slot.
      </div>
    </div>

    <div class="mt-12 border-t pt-8">
      <a href={APP_STORE_URL} class="inline-block px-6 py-3 bg-black text-white rounded-lg font-semibold hover:bg-gray-800">
        Become a sponsor — get DirtBikeX
      </a>
    </div>
  </section>

  <script>
    // Inline-duplicated from /sponsors.astro (Astro doesn't share <script> across
    // page variants). v5 /sponsors.json positionless pool — canonical shape in
    // infra/submodules/dirtbikex-sponsors/src/schemas/wire.ts. Keep in sync.
    type Rider = { username: string | null; label: string; display_name: string | null; avatar_url: string | null; navigable: boolean; kind: 'pass' | 'airtime'; slot_id: string };
    type Payload = { version: number; generated_at: string; hero_image_url: string | null; pool: Rider[]; sell_capacity?: number | null; airtime_capacity?: number | null };
    const root = document.getElementById('sponsors-app')!;
    const loading = document.getElementById('sponsors-loading')!;
    const errorEl = document.getElementById('sponsors-error')!;
    const content = document.getElementById('sponsors-content')!;
    const empty = document.getElementById('sponsors-empty')!;
    const FORUM_BASE = root.dataset.forumBase!;
    function escapeHTML(s: string): string { return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)); }
    function showable(pool: Rider[]): Rider[] { return pool.filter((r) => r.avatar_url || r.username); }
    function hrefFor(r: Rider): string | null { return r.navigable && r.username ? `${FORUM_BASE}/u/${encodeURIComponent(r.username)}` : null; }
    function riderCell(r: Rider): string {
      const name = r.display_name || r.label || r.username || 'Sponsor';
      const handle = r.display_name && r.label ? r.label : '';
      const img = r.avatar_url ? `<img src="${escapeHTML(r.avatar_url)}" alt="${escapeHTML(name)}" class="w-24 h-24 rounded-full object-cover mb-2" loading="lazy" />` : `<div class="w-24 h-24 rounded-full bg-gray-200 dark:bg-gray-700 mb-2"></div>`;
      const inner = `${img}<span class="text-sm font-medium">${escapeHTML(name)}</span>` + (handle ? `<span class="text-xs text-gray-500">${escapeHTML(handle)}</span>` : '');
      const href = hrefFor(r);
      return href ? `<li><a href="${escapeHTML(href)}" class="flex flex-col items-center text-center hover:opacity-80" target="_blank" rel="noopener noreferrer">${inner}</a></li>` : `<li class="flex flex-col items-center text-center">${inner}</li>`;
    }
    function occupancyRow(title: string, used: number, capacity: number | null | undefined): HTMLElement {
      const wrap = document.createElement('div'); wrap.className = 'mb-4';
      const cap = capacity && capacity > 0 ? capacity : null;
      const label = document.createElement('div'); label.className = 'flex justify-between text-sm mb-1';
      label.innerHTML = `<span class="font-medium">${escapeHTML(title)}</span><span class="text-gray-500 tabular-nums">${cap ? `${used} / ${cap}` : String(used)}</span>`;
      wrap.appendChild(label);
      if (cap) {
        const track = document.createElement('div'); track.className = 'h-3 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden';
        const fill = document.createElement('div'); fill.className = 'h-full rounded-full bg-orange-500';
        fill.style.width = `${Math.min(100, Math.round((Math.min(used, cap) / cap) * 100))}%`;
        track.appendChild(fill); wrap.appendChild(track);
      }
      return wrap;
    }
    async function load() {
      try {
        const resp = await fetch('/api/proxy/sponsors', { cache: 'no-store' });
        if (!resp.ok) throw new Error(`status ${resp.status}`);
        const payload = (await resp.json()) as Payload;
        loading.classList.add('hidden');
        const pool = Array.isArray(payload.pool) ? payload.pool : [];
        const riders = showable(pool);
        if (riders.length === 0) { empty.classList.remove('hidden'); return; }
        content.innerHTML = `<ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 mb-12">${riders.map(riderCell).join('')}</ul>`;
        const passUsed = pool.filter((r) => r.kind === 'pass').length;
        const airtimeUsed = pool.filter((r) => r.kind === 'airtime').length;
        const occ = document.createElement('div'); occ.className = 'border-t pt-8';
        occ.innerHTML = '<h2 class="text-xl font-semibold mb-4">Roster</h2>';
        occ.appendChild(occupancyRow('Featured passes', passUsed, payload.sell_capacity));
        occ.appendChild(occupancyRow('Airtime cards', airtimeUsed, payload.airtime_capacity));
        content.appendChild(occ);
        content.classList.remove('hidden');
      } catch (err) {
        console.error('sponsors:load_failed', err);
        loading.classList.add('hidden');
        errorEl.classList.remove('hidden');
      }
    }
    load();
  </script>
</BaseLayout>
