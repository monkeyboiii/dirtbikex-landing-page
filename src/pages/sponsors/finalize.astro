---
// /sponsors/finalize?token=<> — IAP-path desktop magic-link upload (PLAN_2 §4.2).
// Token in URL = credential. Single-use, 7-day TTL.
// English canonical. [lang]/sponsors/finalize.astro mirrors.
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Upload your sponsor image — DirtBikeX">
  <section class="mx-auto max-w-2xl px-4 py-12">
    <h1 class="text-3xl font-bold mb-2">Upload your sponsor image</h1>
    <p class="text-gray-600 dark:text-gray-300 mb-6">
      PNG, ≤500 KB. Image goes to admin review before it appears on the splash.
      No cancellations or refunds — once uploaded and approved, it runs for the
      slot's full month(s).
    </p>

    <div id="no-token" class="hidden p-4 border-l-4 border-amber-500 bg-amber-50 dark:bg-amber-950 text-amber-900 dark:text-amber-100">
      This link is missing the upload token. Open the URL from your iOS receipt email instead.
    </div>

    <div id="picker" class="hidden">
      <label class="block">
        <span class="block text-sm font-medium mb-2">Choose a PNG file</span>
        <input id="file-input" type="file" accept="image/png" class="block w-full text-sm" />
      </label>
      <div id="preview-wrap" class="hidden mt-6">
        <h2 class="text-lg font-semibold mb-2">Preview</h2>
        <img id="preview" alt="" class="max-w-full h-auto rounded border" />
      </div>
      <div class="mt-6 flex items-center gap-3">
        <button id="upload-btn" class="px-6 py-2 bg-black text-white rounded font-semibold disabled:opacity-50" disabled>
          Upload &amp; finish
        </button>
        <span id="status" class="text-sm text-gray-600"></span>
      </div>
    </div>

    <div id="done" class="hidden p-6 border rounded bg-green-50 dark:bg-green-950 text-green-900 dark:text-green-100">
      <h2 class="text-lg font-semibold mb-2">Image queued for review.</h2>
      <p>
        Once an admin approves it (typically within a day), it goes live on the splash at the next iOS daily refresh.
      </p>
    </div>
  </section>

  <script>
    const MAX_BYTES = 500 * 1024;

    function getParams(): { token: string | null; slot: string | null } {
      const u = new URL(location.href);
      return { token: u.searchParams.get('token'), slot: u.searchParams.get('slot') };
    }

    const { token, slot } = getParams();
    const noTokenEl = document.getElementById('no-token')!;
    const pickerEl = document.getElementById('picker')!;
    const doneEl = document.getElementById('done')!;
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const preview = document.getElementById('preview') as HTMLImageElement;
    const previewWrap = document.getElementById('preview-wrap')!;
    const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement;
    const statusEl = document.getElementById('status')!;

    if (!token || !slot) {
      noTokenEl.classList.remove('hidden');
    } else {
      pickerEl.classList.remove('hidden');
    }

    let picked: File | null = null;
    fileInput.addEventListener('change', () => {
      picked = fileInput.files?.[0] ?? null;
      if (!picked) { uploadBtn.disabled = true; previewWrap.classList.add('hidden'); return; }
      if (picked.type !== 'image/png') {
        statusEl.textContent = 'PNG only.';
        uploadBtn.disabled = true;
        return;
      }
      if (picked.size > MAX_BYTES) {
        statusEl.textContent = `Too large: ${(picked.size / 1024).toFixed(0)} KB (max 500 KB).`;
        uploadBtn.disabled = true;
        return;
      }
      statusEl.textContent = '';
      preview.src = URL.createObjectURL(picked);
      previewWrap.classList.remove('hidden');
      uploadBtn.disabled = false;
    });

    uploadBtn.addEventListener('click', async () => {
      if (!picked || !token || !slot) return;
      uploadBtn.disabled = true;
      statusEl.textContent = 'Requesting upload URL…';
      try {
        // 1. Presign — Worker forwards to sponsorhub with X-Finalize-Token.
        // slot_id comes from the URL (sponsorhub's bookings.ts puts it in
        // finalize_url alongside the token); the token is the credential.
        const presignResp = await fetch(`/sponsors/finalize/api/presign?token=${encodeURIComponent(token)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slot_id: slot, content_type: picked.type, byte_size: picked.size }),
        });
        if (!presignResp.ok) {
          const text = await presignResp.text();
          statusEl.textContent = `presign failed: ${presignResp.status} ${text}`;
          uploadBtn.disabled = false;
          return;
        }
        const presign = await presignResp.json() as {
          upload_url: string;
          object_key: string;
          required_headers: Record<string, string>;
        };

        // 2. PUT directly to OCI.
        statusEl.textContent = 'Uploading to storage…';
        const putResp = await fetch(presign.upload_url, {
          method: 'PUT',
          headers: presign.required_headers,
          body: picked,
        });
        if (!putResp.ok) {
          statusEl.textContent = `storage upload failed: ${putResp.status}`;
          uploadBtn.disabled = false;
          return;
        }

        // 3. Complete — flips slot to image_status=pending + consumes token.
        statusEl.textContent = 'Finalizing…';
        const completeResp = await fetch(`/sponsors/finalize/api/complete?token=${encodeURIComponent(token)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slot_id: slot, object_key: presign.object_key }),
        });
        if (!completeResp.ok) {
          const text = await completeResp.text();
          statusEl.textContent = `complete failed: ${completeResp.status} ${text}`;
          uploadBtn.disabled = false;
          return;
        }

        pickerEl.classList.add('hidden');
        doneEl.classList.remove('hidden');
      } catch (err) {
        console.error('finalize:upload_failed', err);
        statusEl.textContent = `unexpected error: ${String(err)}`;
        uploadBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
