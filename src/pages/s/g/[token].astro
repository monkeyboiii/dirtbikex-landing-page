---
// /s/g/<claim_token> — admin grant claim page (PLAN_2 §4.3).
// Static page; the token is a URL param. Worker proxies the lookup +
// claim calls to sponsorhub. No SSO; recipient self-declares username +
// email. The high-entropy token is the credential.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ui, languages, defaultLang, rtlLocales, type Lang, type UIKey } from '../../../i18n/ui';

// This page is served as a single static asset for every claim token (the
// Worker rewrites /s/g/<token> -> /s/g/__token__), so it can't be rendered
// per-language at build time like the [lang]/ routes. Instead we ship the
// claim strings for every locale and pick one client-side from the browser
// language. Keys resolve per-locale with EN fallback (same rule as t()).
const CLAIM_KEYS = [
  'claim.title', 'claim.loading', 'claim.notFound', 'claim.expired',
  'claim.rateLimited', 'claim.slotDetails', 'claim.username.label',
  'claim.username.placeholder', 'claim.username.hint', 'claim.email.label',
  'claim.nudge', 'claim.nudge.confirm', 'claim.submit', 'claim.uploadNote',
  'claim.done.title', 'claim.done.body', 'claim.expires', 'claim.submitting',
  'claim.tooManyHour', 'claim.userNotFound', 'claim.genericError',
  'claim.confirmResubmit', 'claim.networkError', 'claim.slotSummary',
] as const satisfies readonly UIKey[];

const claimI18n = {
  defaultLang,
  rtl: rtlLocales,
  langs: Object.keys(languages),
  strings: Object.fromEntries(
    (Object.keys(languages) as Lang[]).map((lang) => [
      lang,
      Object.fromEntries(
        CLAIM_KEYS.map((k) => [k, ui[lang][k] ?? ui[defaultLang][k] ?? k]),
      ),
    ]),
  ),
};

// Astro requires at least one explicit path to pre-render at build time for
// dynamic routes when the adapter is static. The placeholder never hits prod
// — real claims are pre-rendered via getStaticPaths === []? Actually static
// adapter requires getStaticPaths to return at least one entry, OR we set
// prerender=false and rely on the Worker to serve at runtime. The Worker
// passes /s/g/* through to env.ASSETS, so Astro must generate a fallback.
//
// Approach: pre-render a single placeholder `__token__`; the Worker
// intercepts /s/g/:token requests and rewrites to /s/g/__token__ before
// hitting ASSETS, which then loads this page. The client-side JS reads the
// actual token from `location.pathname`.
export function getStaticPaths() {
  return [{ params: { token: '__token__' } }];
}
---

<BaseLayout title="Claim your sponsor slot — DirtBikeX">
  <section class="mx-auto max-w-xl px-4 py-12">
    <h1 class="text-3xl font-bold mb-2" data-i18n="claim.title">Claim your sponsor slot</h1>

    <div id="loading" class="text-gray-500 italic" data-i18n="claim.loading">Loading…</div>
    <div id="not-found" class="hidden p-4 border-l-4 border-amber-500 bg-amber-50 dark:bg-amber-950 text-amber-900 dark:text-amber-100" data-i18n="claim.notFound">
      This claim link doesn't exist, has been used, or has been revoked.
    </div>
    <div id="expired" class="hidden p-4 border-l-4 border-amber-500 bg-amber-50 dark:bg-amber-950 text-amber-900 dark:text-amber-100" data-i18n="claim.expired">
      This claim link has expired.
    </div>
    <div id="rate-limited" class="hidden p-4 border-l-4 border-red-500 bg-red-50 dark:bg-red-950 text-red-900 dark:text-red-100" data-i18n="claim.rateLimited">
      Too many attempts. Try again in a bit.
    </div>

    <div id="claim-form" class="hidden">
      <div class="mb-6 p-4 rounded border bg-gray-50 dark:bg-gray-900">
        <div class="text-sm text-gray-600 dark:text-gray-300" data-i18n="claim.slotDetails">Slot details:</div>
        <div id="slot-summary" class="mt-1 font-medium"></div>
        <div id="expires-summary" class="mt-1 text-sm text-gray-500"></div>
        <div id="message" class="hidden mt-3 italic text-gray-700 dark:text-gray-300"></div>
      </div>

      <form id="form" class="space-y-4">
        <label class="block">
          <span class="block text-sm font-medium mb-1" data-i18n="claim.username.label">Forum username</span>
          <input id="forum-username" type="text" required class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" placeholder="Enter your forum username" data-i18n-ph="claim.username.placeholder" />
          <span class="block text-xs text-gray-500 mt-1" data-i18n="claim.username.hint">We'll link the slot to this forum profile.</span>
        </label>
        <label class="block">
          <span class="block text-sm font-medium mb-1" data-i18n="claim.email.label">Contact email</span>
          <input id="contact-email" type="email" required class="block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" />
        </label>
        <div id="nudge" class="hidden p-3 border-l-4 border-yellow-500 bg-yellow-50 dark:bg-yellow-950 text-sm">
          <span data-i18n="claim.nudge">This grant was reserved for a different email. Proceed anyway?</span>
          <label class="block mt-2"><input id="confirm-mismatch" type="checkbox" /> <span data-i18n="claim.nudge.confirm">Yes, I understand</span></label>
        </div>
        <div class="flex items-center gap-3">
          <button id="submit" type="submit" class="px-6 py-2 bg-black text-white rounded font-semibold disabled:opacity-50" data-i18n="claim.submit">
            Claim my sponsor slot
          </button>
          <span id="status" class="text-sm text-gray-600"></span>
        </div>
      </form>

      <p class="mt-8 text-xs text-gray-500" data-i18n="claim.uploadNote">
        To upload a custom hero image after claiming, open the DirtBikeX iOS app and go to Profile → My Sponsorships.
        No refunds or cancellations.
      </p>
    </div>

    <div id="done" class="hidden p-6 border rounded bg-green-50 dark:bg-green-950 text-green-900 dark:text-green-100">
      <h2 class="text-lg font-semibold mb-2" data-i18n="claim.done.title">Your sponsor slot is live.</h2>
      <p class="text-sm" data-i18n="claim.done.body">
        To upload a custom hero image, open the DirtBikeX iOS app and go to Profile → My Sponsorships.
      </p>
    </div>
  </section>

  <script type="application/json" id="claim-i18n" set:html={JSON.stringify(claimI18n)} />

  <script>
    // Read token from /s/g/<token> path. The Astro static build emits
    // /s/g/__token__/index.html as a fallback; the Worker rewrites unmatched
    // /s/g/<actual_token> requests to this asset before serving.
    function getToken(): string {
      const m = location.pathname.match(/^\/s\/g\/([^/]+)\/?$/);
      return m ? decodeURIComponent(m[1]!) : '';
    }
    const token = getToken();

    const loadingEl = document.getElementById('loading')!;
    const notFoundEl = document.getElementById('not-found')!;
    const expiredEl = document.getElementById('expired')!;
    const rateLimitedEl = document.getElementById('rate-limited')!;
    const claimFormEl = document.getElementById('claim-form')!;
    const slotSummaryEl = document.getElementById('slot-summary')!;
    const expiresSummaryEl = document.getElementById('expires-summary')!;
    const messageEl = document.getElementById('message')!;
    const formEl = document.getElementById('form') as HTMLFormElement;
    const usernameInput = document.getElementById('forum-username') as HTMLInputElement;
    const emailInput = document.getElementById('contact-email') as HTMLInputElement;
    const nudgeEl = document.getElementById('nudge')!;
    const confirmMismatchInput = document.getElementById('confirm-mismatch') as HTMLInputElement;
    const submitBtn = document.getElementById('submit') as HTMLButtonElement;
    const statusEl = document.getElementById('status')!;
    const doneEl = document.getElementById('done')!;

    // --- i18n: pick a locale from the browser and apply the shipped strings.
    // This page is one static asset for all tokens, so language is resolved
    // client-side rather than at build time.
    type ClaimI18n = {
      defaultLang: string;
      rtl: string[];
      langs: string[];
      strings: Record<string, Record<string, string>>;
    };
    const i18n = JSON.parse(
      document.getElementById('claim-i18n')!.textContent!,
    ) as ClaimI18n;

    function pickLang(): string {
      // ?lang= wins so a shared URL like /s/g/<token>?lang=zh-CN renders
      // deterministically. The LangSwitcher writes this form on /s/* pages
      // (preserves the AASA `/s/*` universal-link contract).
      const qs = new URLSearchParams(location.search).get('lang');
      if (qs && i18n.langs.includes(qs)) return qs;

      const navLangs = navigator.languages?.length
        ? navigator.languages
        : [navigator.language || i18n.defaultLang];
      for (const raw of navLangs) {
        const tag = raw.toLowerCase();
        const exact = i18n.langs.find((l) => l.toLowerCase() === tag);
        if (exact) return exact;
        const base = tag.split('-')[0]!;
        if (base === 'zh') {
          const want = /hant|tw|hk|mo/.test(tag) ? 'zh-TW' : 'zh-CN';
          if (i18n.langs.includes(want)) return want;
        }
        const byBase = i18n.langs.find((l) => l.toLowerCase().split('-')[0] === base);
        if (byBase) return byBase;
      }
      return i18n.defaultLang;
    }

    const lang = pickLang();
    const dict = i18n.strings[lang] ?? i18n.strings[i18n.defaultLang]!;

    function t(key: string, vars: Record<string, string | number> = {}): string {
      let s = dict[key] ?? key;
      for (const [k, v] of Object.entries(vars)) s = s.split(`{${k}}`).join(String(v));
      return s;
    }

    document.documentElement.lang = lang;
    if (i18n.rtl.includes(lang)) document.documentElement.dir = 'rtl';
    document.title = `${t('claim.title')} — DirtBikeX`;
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      el.textContent = t(el.dataset.i18n!);
    });
    document.querySelectorAll<HTMLElement>('[data-i18n-ph]').forEach((el) => {
      el.setAttribute('placeholder', t(el.dataset.i18nPh!));
    });

    function showOnly(el: HTMLElement) {
      loadingEl.classList.add('hidden');
      [notFoundEl, expiredEl, rateLimitedEl, claimFormEl, doneEl].forEach((e) => e.classList.add('hidden'));
      el.classList.remove('hidden');
    }

    async function load() {
      if (!token || token === '__token__') {
        showOnly(notFoundEl);
        return;
      }
      try {
        const resp = await fetch(`/s/g/${encodeURIComponent(token)}/api/lookup`, { cache: 'no-store' });
        if (resp.status === 404) { showOnly(notFoundEl); return; }
        if (resp.status === 410) {
          const body = await resp.json().catch(() => ({}));
          showOnly(body?.reason === 'grant_expired' ? expiredEl : notFoundEl);
          return;
        }
        if (resp.status === 429) { showOnly(rateLimitedEl); return; }
        if (!resp.ok) { showOnly(notFoundEl); return; }
        const grant = (await resp.json()) as {
          section: string;
          slot_order: number;
          month: string;
          grant_mode: 'email_pinned' | 'open';
          identity_hint: { forum_username?: string; brand_name?: string } | null;
          grant_message_public: string | null;
          expires_at: string;
        };
        slotSummaryEl.textContent = t('claim.slotSummary', {
          section: grant.section,
          slotOrder: grant.slot_order,
          month: grant.month,
        });
        expiresSummaryEl.textContent = t('claim.expires', {
          date: new Date(grant.expires_at).toLocaleDateString(lang),
        });
        if (grant.grant_message_public) {
          messageEl.textContent = grant.grant_message_public;
          messageEl.classList.remove('hidden');
        }
        if (grant.identity_hint?.forum_username) {
          usernameInput.value = grant.identity_hint.forum_username;
        }
        showOnly(claimFormEl);
      } catch (err) {
        console.error('claim:lookup_failed', err);
        showOnly(notFoundEl);
      }
    }

    formEl.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      submitBtn.disabled = true;
      statusEl.textContent = t('claim.submitting');
      try {
        const body: Record<string, unknown> = {
          forum_username: usernameInput.value.trim(),
          contact_email: emailInput.value.trim(),
        };
        if (!nudgeEl.classList.contains('hidden') && confirmMismatchInput.checked) {
          body.confirm_email_mismatch = true;
        }
        const resp = await fetch(`/s/g/${encodeURIComponent(token)}/api/claim`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (resp.status === 429) {
          statusEl.textContent = t('claim.tooManyHour');
          submitBtn.disabled = false;
          return;
        }
        const respBody = (await resp.json()) as { slot_id?: string | null; email_mismatch_nudge?: boolean; error?: string; reason?: string };
        if (resp.status === 400 && respBody.reason === 'forum_user_not_found') {
          statusEl.textContent = t('claim.userNotFound', { name: usernameInput.value });
          submitBtn.disabled = false;
          return;
        }
        if (!resp.ok) {
          statusEl.textContent = t('claim.genericError', { error: String(respBody.error ?? resp.status) });
          submitBtn.disabled = false;
          return;
        }
        if (respBody.email_mismatch_nudge) {
          nudgeEl.classList.remove('hidden');
          statusEl.textContent = t('claim.confirmResubmit');
          submitBtn.disabled = false;
          return;
        }
        showOnly(doneEl);
      } catch (err) {
        console.error('claim:submit_failed', err);
        statusEl.textContent = t('claim.networkError', { error: String(err) });
        submitBtn.disabled = false;
      }
    });

    load();
  </script>
</BaseLayout>
