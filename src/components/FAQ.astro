---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const items = [
  { q: t('faq.q1.q'), a: t('faq.q1.a') },
  { q: t('faq.q2.q'), a: t('faq.q2.a') },
  { q: t('faq.q3.q'), a: t('faq.q3.a') },
  { q: t('faq.q4.q'), a: t('faq.q4.a') },
];
---

<section id="faq" class="container-narrow py-20 scroll-mt-20">
  <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-center">
    {t('faq.title')}
  </h2>
  <div class="mt-10 mx-auto max-w-3xl divide-y divide-clay-200 dark:divide-clay-800 border border-clay-200 dark:border-clay-800 rounded-2xl bg-white dark:bg-clay-900">
    {items.map((it) => (
      <details class="group p-5">
        <summary class="cursor-pointer list-none flex items-center justify-between font-medium">
          <span>{it.q}</span>
          <span class="ml-4 text-dirt-500 transition-transform group-open:rotate-45 text-xl leading-none">+</span>
        </summary>
        <p class="mt-3 text-clay-700 dark:text-clay-300 leading-relaxed">{it.a}</p>
      </details>
    ))}
  </div>
</section>
