---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-clay-200 dark:border-clay-800 mt-12">
  <div class="container-narrow py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <img src="/favicon.svg" alt="" class="h-6 w-6" />
      <span class="text-sm text-clay-600 dark:text-clay-400">{t('footer.tagline')}</span>
    </div>
    <nav class="flex items-center gap-6 text-sm">
      <a href={localizedPath(lang, '/privacy')} class="hover:text-dirt-600">
        {t('footer.legal.privacy')}
      </a>
      <a href={localizedPath(lang, '/terms')} class="hover:text-dirt-600">
        {t('footer.legal.terms')}
      </a>
      <a href="https://forum.dirtbikex.com" class="hover:text-dirt-600">forum</a>
    </nav>
    <p class="text-xs text-clay-500 dark:text-clay-500">
      {t('footer.copyright', { year })}
    </p>
  </div>
</footer>
