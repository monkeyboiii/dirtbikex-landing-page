---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import { FORUM_BASE, SOCIALS, SUPPORT_EMAIL } from '../config';
import SocialLinks from './SocialLinks.astro';
import AppStoreBadge from './AppStoreBadge.astro';
import GooglePlayBadge from './GooglePlayBadge.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const home = localizedPath(lang, '/');
const footerSocials = [
  { platform: 'facebook' as const, url: SOCIALS.facebook, label: t('contact.social.facebook') },
  { platform: 'instagram' as const, url: SOCIALS.instagram, label: t('contact.social.instagram') },
  { platform: 'x' as const, url: SOCIALS.x, label: t('contact.social.x') },
  { platform: 'whatsapp' as const, url: SOCIALS.whatsapp, label: t('contact.social.whatsapp') },
  { platform: 'email' as const, url: `mailto:${SUPPORT_EMAIL}`, label: t('contact.social.email') },
];
---

<footer class="site-footer">
  <div class="container-narrow site-footer__inner">
    <div>
      <a href={home} class="site-brand">
        <img src="/brand/logo-lockup.svg" alt="DirtBikeX" class="site-brand__lockup" />
      </a>
      <p class="site-footer__tag">{t('footer.tagline')}</p>
      <div style="margin-top: 20px; display: flex; gap: 10px; flex-wrap: wrap;">
        <AppStoreBadge />
        <GooglePlayBadge />
      </div>
    </div>

    <nav class="site-footer__groups" aria-label="Footer">
      <div class="site-footer__group">
        <h3 class="site-footer__group-title">{t('footer.group.community')}</h3>
        <a href={FORUM_BASE} target="_blank" rel="noopener">{t('footer.forum')}</a>
        <a href={localizedPath(lang, '/founders')}>{t('footer.founders')}</a>
        <a href={localizedPath(lang, '/sponsors')}>{t('footer.sponsors')}</a>
        <a href={localizedPath(lang, '/sponsorship')}>{t('footer.sponsorship')}</a>
      </div>
      <div class="site-footer__group">
        <h3 class="site-footer__group-title">{t('footer.group.support')}</h3>
        <a href={localizedPath(lang, '/contact')}>{t('footer.contact')}</a>
        <a href={localizedPath(lang, '/safety')}>{t('footer.legal.safety')}</a>
        <a href={localizedPath(lang, '/community-guidelines')}>{t('footer.legal.community')}</a>
      </div>
      <div class="site-footer__group">
        <h3 class="site-footer__group-title">{t('footer.group.legal')}</h3>
        <a href={localizedPath(lang, '/privacy')}>{t('footer.legal.privacy')}</a>
        <a href={localizedPath(lang, '/terms')}>{t('footer.legal.terms')}</a>
        <a href={localizedPath(lang, '/cookies')}>{t('footer.legal.cookies')}</a>
        <a href={localizedPath(lang, '/dmca')}>{t('footer.legal.dmca')}</a>
        <a href={localizedPath(lang, '/sponsor-terms')}>{t('footer.legal.sponsors')}</a>
      </div>
    </nav>
  </div>
  <div class="container-narrow">
    <div class="site-footer__locales">
      <SocialLinks links={footerSocials} />
    </div>
    <p class="site-footer__copy">{t('footer.copyright', { year })}</p>
  </div>
</footer>
