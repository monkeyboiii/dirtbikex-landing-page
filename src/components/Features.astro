---
import FeatureCard from './FeatureCard.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const items = [
  { title: t('features.f1.title'), body: t('features.f1.body') },
  { title: t('features.f2.title'), body: t('features.f2.body') },
  { title: t('features.f3.title'), body: t('features.f3.body') },
  { title: t('features.f4.title'), body: t('features.f4.body') },
];
---

<section id="features" class="container-narrow py-20 scroll-mt-20">
  <div class="text-center max-w-2xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight">{t('features.title')}</h2>
    <p class="mt-3 text-clay-700 dark:text-clay-300">{t('features.subtitle')}</p>
  </div>
  <div class="mt-12 grid sm:grid-cols-2 gap-5">
    {items.map((it) => <FeatureCard title={it.title} body={it.body} />)}
  </div>
</section>
