---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const chipRows = [
  ['features.chip.bikes', 'features.chip.riding', 'features.chip.trails'],
  ['features.chip.gear', 'features.chip.maintenance', 'features.chip.racing'],
  ['features.chip.builds', 'features.chip.safety', 'features.chip.more'],
] as const;
const chipAccents = [
  [null, 'brand', null],
  [null, null, 'dark'],
  [null, null, 'empty'],
];

const cards = [
  {
    icon: 'compass' as const,
    title: t('features.f1.title'),
    body: t('features.f1.body'),
    meta: t('features.f1.meta'),
    mediaLabel: t('features.f1.mediaLabel'),
    media: 'chips',
  },
  {
    icon: 'sparkles' as const,
    title: t('features.f2.title'),
    body: t('features.f2.body'),
    meta: t('features.f2.meta'),
    mediaLabel: t('features.f2.mediaLabel'),
    media: 'phone',
  },
  {
    icon: 'share' as const,
    title: t('features.f3.title'),
    body: t('features.f3.body'),
    meta: t('features.f3.meta'),
    mediaLabel: t('features.f3.mediaLabel'),
    media: 'stack',
  },
  {
    icon: 'users' as const,
    title: t('features.f4.title'),
    body: t('features.f4.body'),
    meta: t('features.f4.meta'),
    mediaLabel: t('features.f4.mediaLabel'),
    media: 'avatars',
  },
];

const stackTags = {
  route: t('features.f3.stack.route'),
  photo: t('features.f3.stack.photo'),
  video: t('features.f3.stack.video'),
};

// Real rider photos, each with a one-word interest tag. The "You" slot
// (center, highlighted) uses the founder's own photo.
const riders = [
  { img: '/community/rider-trails.jpg', tag: t('features.f4.tag.trails'), cls: 'a1' },
  { img: '/community/rider-shop.jpg', tag: t('features.f4.tag.builds'), cls: 'a2' },
  { img: '/community/rider-you.jpg', tag: t('features.f4.you'), cls: 'a3' },
  { img: '/community/rider-racer.jpg', tag: t('features.f4.tag.racing'), cls: 'a4' },
  { img: '/community/rider-new.jpg', tag: t('features.f4.tag.newRider'), cls: 'a5' },
];

// Concrete feed-post thumbnails for the "share rides" stack.
const stackImg = {
  route: '/community/post-route.jpg',
  photo: '/community/post-photo.jpg',
  video: '/community/post-video.jpg',
};
---

<section class="section" id="features">
  <div class="container-narrow">
    <div class="section__head">
      <div class="section__eyebrow">{t('features.eyebrow')}</div>
      <h2 class="section__title">{t('features.title')}</h2>
      <p class="section__sub">{t('features.subtitle')}</p>
    </div>

    <div class="feature-grid">
      {cards.map((c) => (
        <article class="feature">
          <div class="feature__media">
            <div class="feature__icon-tag"><Icon name={c.icon} size={18} /></div>
            <div class="feature__media-label">{c.mediaLabel}</div>

            {c.media === 'chips' && (
              <div class="media-chips">
                {chipRows.flatMap((row, ri) =>
                  row.map((key, ci) => (
                    <span class={`media-chip${chipAccents[ri][ci] ? ' ' + chipAccents[ri][ci] : ''}`}>{t(key)}</span>
                  ))
                )}
              </div>
            )}

            {c.media === 'phone' && (
              <div class="media-phone">
                <div class="media-phone__notch"></div>
                <div class="media-phone__screen">
                  <div class="media-phone__status"><span>9:41</span><span>●●●</span></div>
                  <div class="media-phone__row">
                    <div class="media-phone__av"></div>
                    <div class="media-phone__lines">
                      <div class="media-phone__l brand"></div>
                      <div class="media-phone__l short"></div>
                    </div>
                  </div>
                  <div class="media-phone__row">
                    <div class="media-phone__av b"></div>
                    <div class="media-phone__lines">
                      <div class="media-phone__l medium"></div>
                      <div class="media-phone__l short"></div>
                    </div>
                  </div>
                  <div class="media-phone__row">
                    <div class="media-phone__av c"></div>
                    <div class="media-phone__lines">
                      <div class="media-phone__l medium"></div>
                      <div class="media-phone__l short"></div>
                    </div>
                  </div>
                </div>
              </div>
            )}

            {c.media === 'stack' && (
              <div class="media-stack">
                <div class="media-thumb media-thumb__1">
                  <img src={stackImg.route} alt="" loading="lazy" decoding="async" />
                  <span class="media-thumb__tag">{stackTags.route}</span>
                </div>
                <div class="media-thumb media-thumb__2">
                  <img src={stackImg.photo} alt="" loading="lazy" decoding="async" />
                  <span class="media-thumb__tag">{stackTags.photo}</span>
                </div>
                <div class="media-thumb media-thumb__3">
                  <img src={stackImg.video} alt="" loading="lazy" decoding="async" />
                  <div class="media-thumb__play"><Icon name="play" size={12} /></div>
                  <span class="media-thumb__tag">{stackTags.video}</span>
                </div>
              </div>
            )}

            {c.media === 'avatars' && (
              <div class="media-avatars">
                {riders.map((r) => (
                  <div class={`media-rider ${r.cls}`}>
                    <div class="media-av"><img src={r.img} alt="" loading="lazy" decoding="async" /></div>
                    {r.tag && <span class="media-rider__tag">{r.tag}</span>}
                  </div>
                ))}
              </div>
            )}
          </div>

          <div class="feature__body-wrap">
            <h3 class="feature__title">{c.title}</h3>
            <p class="feature__body">{c.body}</p>
            <div class="feature__meta">
              <span>{c.meta}</span>
              <span class="feature__meta__arrow"><Icon name="arrow-right" size={14} /></span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
