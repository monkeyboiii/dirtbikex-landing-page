---
// Official Google Play badge — muted, non-interactive until the Android build ships.
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  size?: 'sm' | 'md' | 'lg';
}
const { size = 'md' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const h = size === 'lg' ? 48 : size === 'sm' ? 34 : 40;
const w = Math.round(h * 3.375);
---

<span
  class="store-badge store-badge--soon"
  role="img"
  aria-label={`${t('cta.googlePlay.line1')} ${t('cta.googlePlay.line2')}`}
>
  <img src="/badges/google-play.svg" alt="" width={w} height={h} decoding="async" />
</span>

<style>
  .store-badge { display: inline-flex; }
  .store-badge img { display: block; }
  .store-badge--soon { opacity: 0.5; cursor: default; }
</style>
