---
import { getLangFromUrl, switchLangPath } from '../i18n/utils';
import { languages, type Lang } from '../i18n/ui';

const current = getLangFromUrl(Astro.url);

const entries = (Object.keys(languages) as Lang[]).map((code) => ({
  code,
  native: languages[code].native,
  href: switchLangPath(Astro.url, code),
  active: code === current,
}));

const currentEntry = entries.find((e) => e.active) ?? entries[0];
---

<details class="langswitch-dd" data-langswitch>
  <summary class="langswitch-dd__btn" aria-label="Switch language">
    <span class="langswitch-dd__current">{currentEntry.native}</span>
    <svg
      class="langswitch-dd__chevron"
      width="12"
      height="12"
      viewBox="0 0 12 12"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M3 4.5L6 7.5L9 4.5"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </summary>
  <ul class="langswitch-dd__menu" role="menu">
    {entries.map((e) => (
      <li role="none">
        <a
          role="menuitem"
          href={e.href}
          hreflang={e.code}
          class={`langswitch-dd__item${e.active ? ' active' : ''}`}
          data-locale={e.code}
          data-lang-link
        >
          <span class="langswitch-dd__item-native">{e.native}</span>
          <span class="langswitch-dd__item-code">{e.code}</span>
        </a>
      </li>
    ))}
  </ul>
</details>

<script is:inline>
  (function () {
    // On worker-rendered share pages (/s/<kind>/<token>) the build-time
    // hrefs bake the prerender placeholder (e.g. /s/<kind>/__token__/) into
    // each locale link, which then 404s. Worse, those /<locale>/s/...
    // URLs sit outside the AASA `/s/*` deep-link contract. Rewrite at
    // runtime: keep location.pathname intact and put the target locale
    // in ?lang= so the URL remains a valid universal link.
    if (location.pathname.startsWith('/s/')) {
      var defaultLang = 'en';
      document.querySelectorAll('[data-langswitch] [data-locale]').forEach(function (el) {
        var target = el.getAttribute('data-locale') || defaultLang;
        var href = target === defaultLang
          ? location.pathname
          : location.pathname + '?lang=' + encodeURIComponent(target);
        el.setAttribute('href', href);
      });
    }

    // Persist explicit user choice so the auto-redirect (BaseLayout)
    // doesn't override the next visit. Keyed by clicks within any
    // LangSwitcher dropdown on the page.
    document.querySelectorAll('[data-langswitch] [data-locale]').forEach((el) => {
      el.addEventListener('click', () => {
        try {
          localStorage.setItem('dbx-locale-pref', el.getAttribute('data-locale') || '');
          localStorage.setItem('dbx-locale-source', 'manual');
        } catch (e) {}
      });
    });
    // Close the dropdown when clicking outside.
    document.addEventListener('click', (e) => {
      document.querySelectorAll('details[data-langswitch][open]').forEach((d) => {
        if (!d.contains(e.target)) d.removeAttribute('open');
      });
    });
  })();
</script>
