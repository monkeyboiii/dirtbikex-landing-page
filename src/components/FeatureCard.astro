---
interface Props {
  title: string;
  body: string;
}
const { title, body } = Astro.props;
---

<div class="rounded-2xl border border-clay-200 dark:border-clay-800 bg-white dark:bg-clay-900 p-6 shadow-sm">
  <h3 class="text-lg font-semibold">{title}</h3>
  <p class="mt-2 text-clay-700 dark:text-clay-300 leading-relaxed">{body}</p>
</div>
