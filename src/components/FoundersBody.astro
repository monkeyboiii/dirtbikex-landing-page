---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { SOCIALS } from '../config';
import SocialIcon from './SocialIcon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

type Founder = {
  nameKey: string;
  roleKey: string;
  photo?: { src: string; altKey: string };
  initials?: string;
  socials?: SocialLink[];
  tba?: boolean;
};

type SocialLink = {
  platform: 'x' | 'instagram' | 'facebook';
  labelKey: string;
  url: string;
};

// Lead founder — rendered on a dedicated full-width row.
const lead = {
  nameKey: 'founders.calvin.name',
  roleKey: 'founders.calvin.role',
  bioKey: 'founders.calvin.bio',
  photo: { src: '/founders/calvin.png', altKey: 'founders.calvin.photo_alt' },
  socials: [
    { platform: 'x', labelKey: 'contact.social.x', url: SOCIALS.x },
    { platform: 'instagram', labelKey: 'contact.social.instagram', url: SOCIALS.instagram },
    { platform: 'facebook', labelKey: 'contact.social.facebook', url: SOCIALS.facebook },
  ],
};

// Photo-first team row. TBA slots render a placeholder portrait until a
// real photo + strings are supplied.
const team: Founder[] = [
  {
    nameKey: 'founders.rebecca.name',
    roleKey: 'founders.rebecca.role',
    initials: 'R',
    socials: [
      { platform: 'x', labelKey: 'contact.social.x', url: '#' },
      { platform: 'instagram', labelKey: 'contact.social.instagram', url: '#' },
    ],
  },
  {
    nameKey: 'founders.cici.name',
    roleKey: 'founders.cici.role',
    initials: 'C',
  },
  { nameKey: 'founders.secret.name', roleKey: 'founders.secret.role', tba: true },
];
---

<section class="container-narrow py-20">
  <header class="text-center">
    <h1 class="t-display-3">{t('founders.title')}</h1>
    <p class="t-body-lg mt-6 mx-auto max-w-prose" style="color: var(--fg-secondary);">
      {t('founders.intro')}
    </p>
  </header>

  <article class="founder-lead mt-16">
    <div class="founder-lead__photo">
      <img
        src={lead.photo.src}
        alt={t(lead.photo.altKey)}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div class="founder-lead__body">
      <h2 class="t-display-3">{t(lead.nameKey)}</h2>
      <p class="t-mono-sm mt-3 uppercase founder-role" style="color: var(--brand);">
        {t(lead.roleKey)}
      </p>
      <p class="t-body-lg mt-5" style="color: var(--fg-secondary);">
        {t(lead.bioKey)}
      </p>
      <ul class="founder-socials mt-6">
        {lead.socials.map((social) => (
          <li>
            <a
              href={social.url}
              target={social.url.startsWith('http') ? '_blank' : undefined}
              rel={social.url.startsWith('http') ? 'noopener' : undefined}
              class="founder-social"
              aria-label={t(social.labelKey)}
              title={t(social.labelKey)}
            >
              <SocialIcon platform={social.platform} />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </article>

  <ul class="founder-grid mt-6 list-none p-0">
    {team.map((f) => (
      <li class={`founder-card${f.tba ? ' tba' : ''}`}>
        <div class="founder-card__photo">
          {f.photo
            ? <img src={f.photo.src} alt={t(f.photo.altKey)} loading="lazy" decoding="async" />
            : f.tba
              ? <svg class="founder-card__silhouette" viewBox="0 0 120 150" fill="currentColor" aria-hidden="true">
                  <circle cx="60" cy="52" r="26" />
                  <path d="M60 88c-30 0-46 20-46 46v16h92v-16c0-26-16-46-46-46z" />
                </svg>
              : <span class="founder-card__initials" aria-hidden="true">{f.initials}</span>}
        </div>
        <div class="founder-card__meta">
          <h3 class="t-h3">{t(f.nameKey)}</h3>
          <p class="t-mono-sm mt-1 uppercase founder-role" style="color: var(--fg-secondary);">
            {t(f.roleKey)}
          </p>
          {f.socials && (
            <ul class="founder-socials founder-socials--card">
              {f.socials.map((social) => (
                <li>
                  <a
                    href={social.url}
                    target={social.url.startsWith('http') ? '_blank' : undefined}
                    rel={social.url.startsWith('http') ? 'noopener' : undefined}
                    class="founder-social"
                    aria-label={t(social.labelKey)}
                    title={t(social.labelKey)}
                  >
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      {social.platform === 'x'
                        ? <path d="M14.1 10.2 22.2 1h-1.9l-7 7.9L7.7 1H1.2l8.5 12.1L1.2 23h1.9l7.5-8.6 6 8.6h6.4l-8.9-12.8Zm-2.7 3.1-.9-1.2L3.7 2.5h3.1l5.5 7.8.9 1.2 7.1 10h-3.1l-5.8-8.2Z" fill="currentColor" stroke="none" />
                        : <>
                            <rect x="3" y="3" width="18" height="18" rx="5" />
                            <circle cx="12" cy="12" r="4" />
                            <circle cx="17.2" cy="6.8" r="1.2" />
                          </>}
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </li>
    ))}
  </ul>
</section>

<style>
  .founder-role { letter-spacing: 0.08em; }

  .founder-socials {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
  }
  .founder-socials--card { margin-top: var(--space-4); }
  .founder-social {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-sunken);
    border: 1px solid var(--border);
    color: var(--fg-secondary);
    transition: background-color var(--dur-fast) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out),
                color var(--dur-fast) var(--ease-out),
                transform var(--dur-fast) var(--ease-out);
  }
  .founder-social:hover {
    background: var(--brand);
    border-color: var(--brand);
    color: #fff;
    transform: translateY(-1px);
  }
  .founder-social svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .founder-lead {
    display: grid;
    grid-template-columns: minmax(220px, 320px) 1fr;
    gap: var(--space-10);
    align-items: center;
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }
  @media (max-width: 700px) {
    .founder-lead {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
  .founder-lead__photo {
    aspect-ratio: 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-sunken);
  }
  .founder-lead__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .founder-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .founder-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .founder-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xs);
  }
  .founder-card.tba { border-style: dashed; }
  .founder-card__photo {
    aspect-ratio: 4 / 5;
    display: grid;
    place-items: center;
    background: var(--bg-sunken);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .founder-card.tba .founder-card__photo { border-bottom-style: dashed; }
  .founder-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .founder-card__initials {
    width: 45%;
    aspect-ratio: 1;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--brand);
    color: #fff;
    font: 700 clamp(36px, 5vw, 56px) var(--font-display);
    box-shadow: var(--shadow-brand);
  }
  .founder-card__silhouette {
    width: 50%;
    color: color-mix(in oklab, var(--fg) 12%, transparent);
  }
  .founder-card__meta {
    padding: var(--space-4) var(--space-5) var(--space-5);
  }
</style>
