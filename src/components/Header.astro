---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import { APP_STORE_URL, FORUM_BASE } from '../config';
import LangSwitcher from './LangSwitcher.astro';
import Icon from './Icon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizedPath(lang, '/');
---

<header class="site-header">
  <div class="container-narrow site-header__inner">
    <a href={home} class="site-brand">
      <img src="/brand/logo-lockup.svg" alt="DirtBikeX" class="site-brand__lockup" />
    </a>

    <nav class="site-nav">
      <a href={localizedPath(lang, '/founders')}>{t('nav.founders')}</a>
      <a href={localizedPath(lang, '/sponsorship')}>{t('nav.sponsors')}</a>
      <a href={FORUM_BASE} target="_blank" rel="noopener">{t('nav.community')}</a>
    </nav>

    <div class="site-tools">
      <LangSwitcher />
      <button
        type="button"
        id="theme-toggle"
        aria-label={t('nav.toggleTheme')}
        class="icon-btn"
      >
        <span class="hidden dark:inline-flex"><Icon name="sun" size={18} /></span>
        <span class="inline-flex dark:hidden"><Icon name="moon" size={18} /></span>
      </button>
      <a href={APP_STORE_URL} target="_blank" rel="noopener" class="btn btn--primary">{t('nav.getApp')}</a>
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const isDark = root.classList.toggle('dark');
    try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) {}
  });
  (function () {
    const header = document.querySelector('.site-header');
    if (!header) return;
    const sync = () => header.toggleAttribute('data-scrolled', window.scrollY > 8);
    window.addEventListener('scroll', sync, { passive: true });
    sync();
  })();
</script>
