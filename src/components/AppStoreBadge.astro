---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { APP_STORE_URL } from '../config';

interface Props {
  size?: 'sm' | 'md';
  class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const sizeClasses =
  size === 'sm'
    ? 'h-10 px-3 text-[10px]'
    : 'h-14 px-5 text-xs';
const lineTwoClasses = size === 'sm' ? 'text-base' : 'text-xl';
---

<a
  href={APP_STORE_URL}
  target="_blank"
  rel="noopener"
  aria-label={`${t('cta.appStore.line1')} ${t('cta.appStore.line2')}`}
  class:list={[
    'inline-flex items-center gap-3 rounded-xl bg-black text-white hover:bg-clay-800 transition-colors',
    sizeClasses,
    className,
  ]}
>
  <svg viewBox="0 0 24 24" class:list={[size === 'sm' ? 'h-5 w-5' : 'h-7 w-7']} fill="currentColor" aria-hidden="true">
    <path d="M16.365 1.43c0 1.14-.42 2.18-1.13 2.95-.85.93-2.24 1.65-3.41 1.55-.13-1.12.4-2.27 1.1-3.02C13.78.94 15.2.18 16.36 0c.05.48-.01 1.05 0 1.43zM21 17.41c-.55 1.27-.81 1.83-1.52 2.95-.99 1.56-2.39 3.5-4.12 3.51-1.54.02-1.94-1-4.03-.99-2.09.01-2.53.99-4.07.97-1.73-.02-3.06-1.77-4.05-3.33C.61 16.36-.16 11.05 1.96 7.66c1.5-2.4 3.87-3.81 6.1-3.81 2.27 0 3.7 1.25 5.57 1.25 1.81 0 2.92-1.25 5.55-1.25 1.99 0 4.1 1.08 5.6 2.96-4.92 2.7-4.12 9.72.22 10.6z"/>
  </svg>
  <span class="flex flex-col items-start leading-tight">
    <span class="opacity-80">{t('cta.appStore.line1')}</span>
    <span class:list={['font-semibold tracking-tight', lineTwoClasses]}>{t('cta.appStore.line2')}</span>
  </span>
</a>
