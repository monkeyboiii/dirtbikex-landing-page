/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/brand/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

/favicon-16.png
  Cache-Control: public, max-age=31536000, immutable

/favicon-32.png
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

/icon-192.png
  Cache-Control: public, max-age=31536000, immutable

/icon-512.png
  Cache-Control: public, max-age=31536000, immutable

/icon-512-maskable.png
  Cache-Control: public, max-age=31536000, immutable

/og-image.png
  Cache-Control: public, max-age=86400

/site.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=3600

/.well-known/apple-app-site-association
  Content-Type: application/json
  Cache-Control: public, max-age=3600

/api/sponsors.json
  Content-Type: application/json
  Cache-Control: public, max-age=3600, s-maxage=3600

/api/forum/metrics.json
  Content-Type: application/json
  Cache-Control: public, max-age=3600, s-maxage=86400

/api/forum/featured.json
  Content-Type: application/json
  Cache-Control: public, max-age=3600, s-maxage=86400

# Per-token/per-key dynamic routes (rendered by the worker). Never edge-cache:
# during a worker deploy gap the asset layer serves a 404-page here, and any
# s-maxage would pin that transient 404 at a CF PoP for hours.
/s/*
  Cache-Control: no-store

# Worker-handled double-opt-in routes (token-bearing) — never edge-cache.
/join/confirm
  Cache-Control: no-store
/api/unsubscribe
  Cache-Control: no-store

/*
  Cache-Control: public, max-age=300, s-maxage=86400
